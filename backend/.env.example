# ─────────────────────────────────────────────────────────
# Scholarship Finder AI — Backend Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your own values.
# DO NOT commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
# SQLite (development) — use PostgreSQL in production
DATABASE_URL=sqlite:///./scholarships.db
# Supabase / PostgreSQL (production) — use session-mode pooler on port 5432
# Note: URL-encode special chars in password (@ → %40, # → %23, $ → %24)
# DATABASE_URL=postgresql://postgres.PROJECT_ID:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Authentication ────────────────────────────────────────
# Generate a strong secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AI / Groq ─────────────────────────────────────────────
# REQUIRED for AI Chat and eligibility explanations to work.
# Get a FREE key at: https://console.groq.com/keys
# Add this to Render: Dashboard → Your Service → Environment → GROQ_API_KEY
GROQ_API_KEY=your-groq-api-key-here

# ── Render Deployment Notes ────────────────────────────────
# PORT is automatically set by Render — do NOT set manually.
# Set these in Render Dashboard > Environment Variables:
#   DATABASE_URL  → Your Supabase session-mode URL (port 5432)
#   GROQ_API_KEY  → From https://console.groq.com/keys
#   SECRET_KEY    → Any long random string

# ── Scraper ───────────────────────────────────────────────
# New lightweight scraper (http_runner.py) doesn't need Playwright.
# It uses httpx + BeautifulSoup — no extra setup needed.
# Run manually: python backend/scraper/http_runner.py
# Or trigger from Admin panel: POST /scraper/run
PLAYWRIGHT_HEADLESS=true
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; ScholarshipBot/1.0)
