# ─────────────────────────────────────────────────────────
# Scholarship Finder AI — Backend Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your own values.
# DO NOT commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
# SQLite (development) — zero setup required locally
DATABASE_URL=sqlite:///./scholarships.db
# Supabase / PostgreSQL (production) — use session-mode pooler on port 5432
# Note: URL-encode special chars in password (@ → %40, # → %23, $ → %24)
# DATABASE_URL=postgresql://postgres.PROJECT_ID:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres

# ── Authentication ────────────────────────────────────────
# Generate a strong secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI / Groq ─────────────────────────────────────────────
# REQUIRED for AI Chat and eligibility explanations to work.
# Get a FREE key at: https://console.groq.com/keys
# Model used: llama-3.3-70b-versatile
GROQ_API_KEY=your-groq-api-key-here

# ── Scraper ───────────────────────────────────────────────
# Lightweight http_runner.py scraper — no Playwright, no Celery needed.
# Uses httpx + BeautifulSoup4 with APScheduler for scheduling.
# Run manually: python -m backend.scraper.http_runner
# Or trigger via Admin panel: POST /scraper/run
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; ScholarshipBot/2.0)

# ── Source Discovery Producer & AI Consumer ──────────────────
# Controls how many DuckDuckGo results the producer fetches per seed query.
# The producer runs every 48 hours via APScheduler.
DUCKDUCKGO_MAX_RESULTS=10

# The consumer runs every 12 hours via APScheduler and uses GROQ_API_KEY
# to extract scholarship structured data from the discovered HTML.

# ── Render Deployment Notes ────────────────────────────────
# PORT is automatically set by Render — do NOT set manually.
# Set these in Render Dashboard > Environment Variables:
#   DATABASE_URL  → Your Supabase session-mode URL (port 5432)
#   GROQ_API_KEY  → From https://console.groq.com/keys
#   SECRET_KEY    → Any long random string (min 32 chars)
#
# NOT needed on Render (APScheduler runs in-process):
#   Redis / Celery — removed in v1.4.0, replaced by APScheduler
