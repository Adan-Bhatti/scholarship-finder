# ─────────────────────────────────────────────────────────
# Scholarship Finder AI — Backend Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your own values.
# DO NOT commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
# SQLite (development) — use PostgreSQL in production
DATABASE_URL=sqlite:///./scholarships.db
# PostgreSQL (production) example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scholarships

# ── Redis / Celery ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Authentication ────────────────────────────────────────
# Generate a strong secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AI / Groq ─────────────────────────────────────────────
# Get your API key at https://console.groq.com/
# REQUIRED for AI eligibility explanations to work.
# Without this key, the AI explainer will return a placeholder message.
GROQ_API_KEY=your-groq-api-key-here
